{
  "name": "goodlane-freight-agent",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "transcribe": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/transcribe.ts",
    "extract:calls": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/extract-calls.ts",
    "eval": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/eval.ts",
    "eval:intake": "tsx scripts/eval-intake.ts",
    "eval:extraction": "tsx scripts/eval-extraction.ts",
    "eval:deterministic": "npm run eval:intake && npm run eval:extraction"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.0",
    "ai": "^4.3.0",
    "next": "14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "openai": "^4.104.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5"
  }
}
