# OpenAI — required for the agent, offline extraction, and eval
OPENAI_API_KEY=sk-...

# Optional model overrides (defaults shown)
OPENAI_AGENT_MODEL=gpt-4o
OPENAI_EXTRACTION_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe-diarize

# Dataset paths (defaults shown)
DATA_DIR=./goodlane-interview-dataset
TRANSCRIPTS_PATH=./data/transcripts.json
